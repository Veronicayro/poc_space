    Person(analyst, "Analista Financiero", "Registers and edits supplier invoices")
    Person(manager, "Gerente Financiero", "Approves or rejects invoices")
    Person(treasurer, "Tesorero", "Schedules and monitors payments")

    System_Boundary(cxp, "CXP System – Cuentas por Pagar") {

        System_Boundary(exp_layer, "Experience Layer") {
            Container(exp_api, "accounts-payable-exp-api", "Node.js/Express", "BFF – Aggregates invoices + payments for the SPA. RBAC per role. OAuth2/OIDC JWT validation.")
        }

        System_Boundary(biz_layer, "Business Layer") {
            Container(inv_api, "invoice-management-api", "Node.js/Spring Boot", "Invoice lifecycle business service. Validates supplier (ERP), prevents duplicates, orchestrates state transitions. BIAN: AccountsReceivable (adapted).")
            Container(pay_api, "payment-management-api", "Node.js/Spring Boot", "Payment scheduling and execution. Idempotent payment orders, webhook handling, ERP accounting. BIAN: Disbursement (adapted).")
        }

        System_Boundary(domain_layer, "Domain Layer") {
            Container(lfc_api, "invoice-lifecycle-api", "Node.js/Spring Boot", "Pure state machine: PENDING→APPROVED→SCHEDULED→PAID / REJECTED / CANCELLED. Immutable audit trail. No external dependencies.")
        }

        System_Boundary(support_layer, "Support Layer") {
            Container(erp_api, "erp-integration-api", "Node.js/Spring Boot", "ERP adapter (ACL). Supplier validation (5min cache) + ledger posting. Retry + circuit breaker. BIAN: FinancialAccounting (reference).")
            Container(bank_api, "banking-integration-api", "Node.js/Spring Boot", "Banking adapter. Payment orders + inbound HMAC-SHA256 webhooks. Idempotency key. mTLS. BIAN: FinancialGateway (reference).")
        }

        SystemDb(pg_invoices, "PostgreSQL: invoices", "Invoice aggregate. Unique (supplier_id, invoice_number). Indexed by status, supplier_id, due_date.")
        SystemDb(pg_payments, "PostgreSQL: payment_orders", "Payment order aggregate. Idempotency key unique index. Indexed by invoice_id, status.")
        SystemDb(pg_lifecycle, "PostgreSQL: invoice_lifecycle", "State machine tables: invoice_lifecycle, state_transitions (append-only), audit_log (append-only).")
        SystemDb(pg_banking, "PostgreSQL: banking_log", "banking_payment_log + webhook_event_log (deduplication). Append-only.")
    }

    System_Ext(erp_sys, "ERP System", "Central accounting system. Supplier directory + ledger.")
    System_Ext(bank_sys, "Banking System", "External banking platform. Transfers + payment confirmations via webhooks.")
    System_Ext(oidc, "OAuth2/OIDC Provider", "Identity provider – JWT issuance and JWKS endpoint for token validation.")

    BiRel(analyst, exp_api, "HTTPS + JWT ****** ANALYST)")
