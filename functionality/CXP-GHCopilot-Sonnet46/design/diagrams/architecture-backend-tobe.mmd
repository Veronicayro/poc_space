    Rel(exp_api, pay_api, "REST HTTPS – payment scheduling + status")

    Rel(inv_api, lfc_api, "REST HTTPS – state transitions (approve/reject/cancel)")
    Rel(inv_api, erp_api, "REST HTTPS – validate supplier (BR-001)")
    Rel(pay_api, lfc_api, "REST HTTPS – state transitions (schedule/paid)")
    Rel(pay_api, bank_api, "REST HTTPS + X-Idempotency-Key – send payment order")
    Rel(pay_api, erp_api, "REST HTTPS – post accounting entry after payment")

